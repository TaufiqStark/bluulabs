# Database Configuration (PostgreSQL)
# You can use standard Postgres connection string from Neon, Supabase, Render, Aiven, etc.
DATABASE_URL="postgres://user:password@host:port/database"

# Filebase (IPFS/S3 Compatible Storage) Configuration
FILEBASE_ACCESS_KEY_ID="your_filebase_access_key"
FILEBASE_SECRET_ACCESS_KEY="your_filebase_secret_key"
FILEBASE_BUCKET_NAME="your_bucket_name"
NEXT_PUBLIC_FILEBASE_GATEWAY_URL="https://dweb.link/ipfs" # Using public IPFS gateway to bypass Private Bucket restrictions

# Admin Authentication (Optional: session secret, NextAuth, or simple password)
ADMIN_PASSWORD="your_secure_password"
